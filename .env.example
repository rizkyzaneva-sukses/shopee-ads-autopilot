# ---- Kredensial Shopee Open Platform (wajib untuk mode LIVE) ----
# Dapatkan dari https://open.shopee.com -> App List -> app Anda.
# Scope iklan (Ads, modul 117) harus diaktifkan dulu oleh Shopee Partner Support.
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=

# Host API: produksi (default) atau sandbox uji
# produksi : https://partner.shopeemobile.com
# sandbox  : https://partner.test-stable.shopee.cn
SHOPEE_BASE_URL=https://partner.shopeemobile.com

# Redirect URL yang didaftarkan di App Console (dipakai scripts/authorize_shop.py)
SHOPEE_REDIRECT_URL=http://127.0.0.1:8765/callback

# Folder penyimpanan token OAuth per toko (JANGAN dibagikan / di-commit)
SHOPEE_TOKEN_DIR=./tokens

# ---- Aplikasi ----
# Lokasi database SQLite (default: autopilot.db di folder aplikasi)
# AUTOPILOT_DB=autopilot.db

# Port server web (default 8765)
# PORT=8765
